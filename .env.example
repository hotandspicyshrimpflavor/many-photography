# Database
DATABASE_URL="postgresql://many:password@localhost:5432/many_photography?schema=public"

# MinIO (Self-hosted S3)
MINIO_ENDPOINT="localhost:9000"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="your-minio-access-key"
MINIO_SECRET_KEY="your-minio-secret-key"
MINIO_BUCKET="many-photography"

# Resend (Email)
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Cloudflare Tunnel (for no-port-forwarding)
CF_TUNNEL_TOKEN="your-cloudflare-tunnel-token"

# Admin Auth
ADMIN_EMAIL="many@manyphotography.com"
ADMIN_PASSWORD="your-secure-admin-password"

# JWT Secret for admin sessions
# MUST be at least 32 characters — generate with: openssl rand -base64 48
JWT_SECRET="replace-with-output-of-openssl-rand-base64-48"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_CLOUDFLARE_TUNNEL_URL="https://many-photography.example.com"
